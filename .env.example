# העתיקו קובץ זה ל-.env ומלאו את הערכים:
#     cp .env.example .env
#
# את מפתח ה-API מקבלים אחרי הרשמה ל-API של Klangio:
#   https://klang.io/api  ->  לאחר אישור, המפתח מופיע בלוח הבקרה: https://api-dashboard.klang.io
# שימו לב: זה ה-API למפתחים, נפרד מהמנוי הרגיל של אפליקציות Klangio.

KLANGIO_API_KEY=

# מודל הזיהוי. עבור פסנתר/קלידים מומלץ "piano".
# אפשרויות: detect, universal, piano, guitar, bass, vocal, lead, drums, wind, string
KLANGIO_MODEL=piano
